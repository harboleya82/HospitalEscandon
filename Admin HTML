<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Dashboard — Encuesta Hospital Escandón</title>
<script src="https://cdn.jsdelivr.net/npm/@supabase/supabase-js@2/dist/umd/supabase.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/chart.js@4/dist/chart.umd.min.js"></script>
<style>
*{margin:0;padding:0;box-sizing:border-box}
body{font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',sans-serif;background:#f1f5f9;color:#1e293b;min-height:100vh}
.header{background:linear-gradient(135deg,#0c4a6e,#0369a1);padding:20px 24px;color:#fff}
.header h1{font-size:22px;font-weight:800}
.header p{font-size:13px;opacity:.7;margin-top:4px}
.login-screen{max-width:400px;margin:80px auto;background:#fff;padding:32px;border-radius:16px;box-shadow:0 4px 12px rgba(0,0,0,.08)}
.login-screen h2{font-size:20px;font-weight:700;color:#0c4a6e;margin-bottom:16px}
.login-screen input{width:100%;padding:12px 14px;border:2px solid #e2e8f0;border-radius:10px;font-size:14px;margin-bottom:12px;font-family:inherit;outline:none}
.login-screen input:focus{border-color:#0c4a6e}
.login-screen button{width:100%;padding:14px;border:none;border-radius:10px;background:#0c4a6e;color:#fff;font-size:15px;font-weight:600;cursor:pointer;font-family:inherit}
.login-screen .error{color:#dc2626;font-size:13px;margin-top:8px;display:none}
.dashboard{display:none;padding:20px 24px;max-width:1200px;margin:0 auto}
.stats{display:grid;grid-template-columns:repeat(auto-fit,minmax(200px,1fr));gap:16px;margin-bottom:24px}
.stat-card{background:#fff;border-radius:14px;padding:20px;box-shadow:0 1px 4px rgba(0,0,0,.06)}
.stat-card .value{font-size:32px;font-weight:800;color:#0c4a6e}
.stat-card .label{font-size:13px;color:#64748b;margin-top:4px}
.charts{display:grid;grid-template-columns:repeat(auto-fit,minmax(340px,1fr));gap:20px;margin-bottom:24px}
.chart-card{background:#fff;border-radius:14px;padding:20px;box-shadow:0 1px 4px rgba(0,0,0,.06)}
.chart-card h3{font-size:15px;font-weight:700;color:#0c4a6e;margin-bottom:12px}
.table-wrap{background:#fff;border-radius:14px;padding:20px;box-shadow:0 1px 4px rgba(0,0,0,.06);overflow-x:auto;margin-bottom:24px}
.table-wrap h3{font-size:15px;font-weight:700;color:#0c4a6e;margin-bottom:12px}
table{width:100%;border-collapse:collapse;font-size:13px}
th{text-align:left;padding:10px 12px;background:#f8fafc;border-bottom:2px solid #e2e8f0;color:#475569;font-weight:600;white-space:nowrap}
td{padding:10px 12px;border-bottom:1px solid #f1f5f9;max-width:200px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap}
tr:hover td{background:#f8fafc}
.btn-row{display:flex;gap:12px;margin-bottom:20px;flex-wrap:wrap}
.btn-action{padding:10px 20px;border-radius:10px;border:2px solid #e2e8f0;background:#fff;font-size:14px;font-weight:600;cursor:pointer;font-family:inherit;color:#475569}
.btn-action:hover{border-color:#0c4a6e;color:#0c4a6e}
.btn-action.primary{background:#0c4a6e;color:#fff;border:none}
.open-text{background:#fff;border-radius:14px;padding:20px;box-shadow:0 1px 4px rgba(0,0,0,.06);margin-bottom:24px}
.open-text h3{font-size:15px;font-weight:700;color:#0c4a6e;margin-bottom:12px}
.open-item{padding:12px 14px;border-left:3px solid #0c4a6e;background:#f8fafc;border-radius:0 8px 8px 0;margin-bottom:8px;font-size:13px;line-height:1.5;color:#334155}
.open-item .meta{font-size:11px;color:#94a3b8;margin-top:4px}
.refresh-note{font-size:12px;color:#94a3b8;text-align:center;margin:20px 0}
</style>
</head>
<body>

<div class="header">
  <h1>📊 Dashboard — Encuesta Hospital Escandón</h1>
  <p>Panel de gestión de respuestas | Datos en tiempo real desde Supabase</p>
</div>

<div class="login-screen" id="loginScreen">
  <h2>🔐 Acceso al dashboard</h2>
  <input type="email" id="loginEmail" placeholder="Email de administrador">
  <input type="password" id="loginPass" placeholder="Contraseña">
  <button onclick="doLogin()">Entrar</button>
  <div class="error" id="loginError"></div>
  <p style="font-size:12px;color:#94a3b8;margin-top:16px;line-height:1.5">
    Usa las credenciales que configuraste en Supabase Authentication.<br>
    Si aún no tienes usuario, créalo en el panel de Supabase → Authentication → Users.
  </p>
</div>

<div class="dashboard" id="dashboard">
  <div class="btn-row">
    <button class="btn-action primary" onclick="loadData()">🔄 Actualizar datos</button>
    <button class="btn-action" onclick="exportAllCSV()">📄 Exportar todo a CSV</button>
    <span id="lastUpdate" style="font-size:12px;color:#94a3b8;align-self:center"></span>
  </div>

  <div class="stats" id="statsCards"></div>
  <div class="charts" id="chartsArea"></div>
  <div id="openTexts"></div>
  <div class="table-wrap">
    <h3>Todas las respuestas</h3>
    <div id="tableArea"></div>
  </div>
  <div class="refresh-note">Los datos se actualizan cada vez que presionas "Actualizar datos"</div>
</div>

<script>
// ============================================
// SUPABASE CONFIG — Mismas credenciales
// ============================================
const SUPABASE_URL = 'https://gggwswbgwihlokrnvktl.supabase.co';
const SUPABASE_ANON_KEY = 'eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6ImdnZ3dzd2Jnd2lobG9rcm52a3RsIiwicm9sZSI6ImFub24iLCJpYXQiOjE3NzQzMjMwMjksImV4cCI6MjA4OTg5OTAyOX0.hyjmonvNM3b9aK4tM8hJGQv7ZF1-1absbczxUwiTCUg';
const sb = window.supabase.createClient(SUPABASE_URL, SUPABASE_ANON_KEY);

let allData = [];

async function doLogin() {
  const email = document.getElementById('loginEmail').value;
  const pass = document.getElementById('loginPass').value;
  const errEl = document.getElementById('loginError');
  errEl.style.display = 'none';

  const { data, error } = await sb.auth.signInWithPassword({ email, password: pass });
  if (error) {
    errEl.textContent = 'Error: ' + error.message;
    errEl.style.display = 'block';
    return;
  }
  document.getElementById('loginScreen').style.display = 'none';
  document.getElementById('dashboard').style.display = 'block';
  loadData();
}

async function loadData() {
  const { data, error } = await sb.from('respuestas_encuesta').select('*').order('created_at', { ascending: false });
  if (error) { alert('Error cargando datos: ' + error.message); return; }
  allData = data || [];
  document.getElementById('lastUpdate').textContent = 'Última actualización: ' + new Date().toLocaleTimeString('es-MX');
  renderStats();
  renderCharts();
  renderOpenTexts();
  renderTable();
}

function renderStats() {
  const n = allData.length;
  const avgP73 = n ? (allData.reduce((s, r) => s + (r.p7_3_probabilidad_aumentar || 0), 0) / n).toFixed(1) : '—';
  
  const likertFields = ['p3_1_reputacion','p3_2_calidad_precio','p3_3_infraestructura','p3_4_recomienda','p3_5_satisfaccion_pacientes','p3_6_vs_corta_estancia'];
  let likertSum = 0, likertCount = 0;
  allData.forEach(r => likertFields.forEach(f => { if(r[f]) { likertSum += r[f]; likertCount++; } }));
  const avgPerception = likertCount ? (likertSum / likertCount).toFixed(1) : '—';

  const hotelFields = ['p5_1_habitaciones','p5_2_limpieza','p5_3_enfermeria_piso','p5_4_alimentos','p5_5_familiares','p5_6_admision_alta','p5_7_imagen_general'];
  let hSum = 0, hCount = 0;
  allData.forEach(r => hotelFields.forEach(f => { if(r[f]) { hSum += r[f]; hCount++; } }));
  const avgHotel = hCount ? (hSum / hCount).toFixed(1) : '—';

  const hotelImpact = n ? allData.filter(r => r.p5_10_hoteleria_influye && (r.p5_10_hoteleria_influye.includes('Probablemente sí') || r.p5_10_hoteleria_influye.includes('Definitivamente sí'))).length : 0;
  const hotelPct = n ? Math.round(hotelImpact / n * 100) : 0;

  document.getElementById('statsCards').innerHTML = `
    <div class="stat-card"><div class="value">${n}</div><div class="label">Respuestas totales</div></div>
    <div class="stat-card"><div class="value">${avgP73}</div><div class="label">Probabilidad de aumentar cirugías (1-10)</div></div>
    <div class="stat-card"><div class="value">${avgPerception}/5</div><div class="label">Percepción general promedio</div></div>
    <div class="stat-card"><div class="value">${avgHotel}/5</div><div class="label">Hotelería promedio</div></div>
    <div class="stat-card"><div class="value" style="color:${hotelPct>30?'#dc2626':'#059669'}">${hotelPct}%</div><div class="label">🚩 Hotelería impacta fuga de pacientes</div></div>
  `;
}

function countField(field) {
  const counts = {};
  allData.forEach(r => {
    const v = r[field];
    if (!v) return;
    const items = typeof v === 'string' && v.includes(';') ? v.split(';').map(s => s.trim()) : [String(v)];
    items.forEach(item => { if(item) counts[item] = (counts[item] || 0) + 1; });
  });
  return counts;
}

function renderCharts() {
  const area = document.getElementById('chartsArea');
  area.innerHTML = '';

  const chartConfigs = [
    { title: '¿Dónde más operan? (Competencia)', field: 'p7_1_otras_instituciones', type: 'bar' },
    { title: 'Razones para operar en otro hospital', field: 'p2_3_razones_otros', type: 'bar' },
    { title: 'Antigüedad de médicos', field: 'p1_2_anos_adscrito', type: 'doughnut' },
    { title: '% de práctica en HE', field: 'p1_4_porcentaje_he', type: 'doughnut' },
    { title: 'Importancia del costo de quirófano', field: 'p8_1_importancia_costo', type: 'doughnut' },
    { title: 'Cambio de mayor impacto', field: 'p9_2_cambio_impacto', type: 'bar' },
    { title: 'Incentivos más atractivos', field: 'p8_2_incentivos_atractivos', type: 'bar' },
    { title: 'Hotelería influye en fuga', field: 'p5_10_hoteleria_influye', type: 'doughnut' },
  ];

  const colors = ['#0c4a6e','#0369a1','#0891b2','#059669','#d97706','#dc2626','#7c3aed','#db2777','#64748b','#475569'];

  chartConfigs.forEach((cfg, i) => {
    const counts = countField(cfg.field);
    if (Object.keys(counts).length === 0) return;
    const labels = Object.keys(counts);
    const values = Object.values(counts);

    const card = document.createElement('div');
    card.className = 'chart-card';
    card.innerHTML = `<h3>${cfg.title}</h3><canvas id="chart${i}"></canvas>`;
    area.appendChild(card);

    new Chart(document.getElementById('chart' + i), {
      type: cfg.type === 'doughnut' ? 'doughnut' : 'bar',
      data: {
        labels: labels.map(l => l.length > 35 ? l.slice(0, 35) + '...' : l),
        datasets: [{
          data: values,
          backgroundColor: cfg.type === 'doughnut' ? colors.slice(0, labels.length) : ['#0c4a6e'],
          borderWidth: 0,
          borderRadius: cfg.type === 'bar' ? 6 : 0,
        }]
      },
      options: {
        responsive: true,
        indexAxis: cfg.type === 'bar' ? 'y' : undefined,
        plugins: { legend: { display: cfg.type === 'doughnut', position: 'bottom', labels: { font: { size: 11 } } } },
        scales: cfg.type === 'bar' ? { x: { beginAtZero: true, ticks: { stepSize: 1 } } } : undefined,
      }
    });
  });
}

function renderOpenTexts() {
  const area = document.getElementById('openTexts');
  area.innerHTML = '';
  const openFields = [
    { field: 'p3_7_opinion_sincera', title: 'Opinión sincera sobre operar en HE' },
    { field: 'p4_10_equipo_necesario', title: 'Equipo/tecnología que necesitan' },
    { field: 'p5_11_mejora_experiencia', title: 'Mejora en experiencia del paciente' },
    { field: 'p6_7_barrera_frustrante', title: 'Barrera administrativa más frustrante' },
    { field: 'p7_4_que_necesita', title: '¿Qué necesitaría HE para más cirugías?' },
    { field: 'deep_5_familiar', title: '🔍 ¿Operaría a un familiar en HE?' },
  ];

  openFields.forEach(cfg => {
    const items = allData.filter(r => r[cfg.field]).map(r => ({
      text: r[cfg.field],
      date: new Date(r.created_at).toLocaleDateString('es-MX'),
      spec: r.p1_1_especialidad || 'No indicó'
    }));
    if (items.length === 0) return;

    const div = document.createElement('div');
    div.className = 'open-text';
    div.innerHTML = `<h3>${cfg.title} (${items.length} respuestas)</h3>` +
      items.map(it => `<div class="open-item">${it.text}<div class="meta">${it.spec} — ${it.date}</div></div>`).join('');
    area.appendChild(div);
  });
}

function renderTable() {
  if (allData.length === 0) {
    document.getElementById('tableArea').innerHTML = '<p style="color:#94a3b8;font-size:14px">No hay respuestas aún.</p>';
    return;
  }
  const cols = ['created_at','p1_1_especialidad','p1_2_anos_adscrito','p2_1_cirugias_total','p2_2_cirugias_he','p7_3_probabilidad_aumentar','p5_10_hoteleria_influye','p9_2_cambio_impacto'];
  const headers = ['Fecha','Especialidad','Antigüedad','Cx Total','Cx HE','Prob. Aumentar','Hotelería→Fuga','Cambio Impacto'];

  let html = '<table><thead><tr>' + headers.map(h => '<th>' + h + '</th>').join('') + '</tr></thead><tbody>';
  allData.forEach(r => {
    html += '<tr>' + cols.map(c => {
      let v = r[c] || '—';
      if (c === 'created_at') v = new Date(v).toLocaleDateString('es-MX');
      return '<td title="' + String(v).replace(/"/g, '&quot;') + '">' + v + '</td>';
    }).join('') + '</tr>';
  });
  html += '</tbody></table>';
  document.getElementById('tableArea').innerHTML = html;
}

function exportAllCSV() {
  if (allData.length === 0) { alert('No hay datos para exportar'); return; }
  const keys = Object.keys(allData[0]).filter(k => k !== 'id' && k !== 'user_agent' && k !== 'ip_approx');
  let csv = keys.join(',') + '\n';
  allData.forEach(r => {
    csv += keys.map(k => {
      let v = r[k] || '';
      v = String(v).replace(/"/g, '""');
      return '"' + v + '"';
    }).join(',') + '\n';
  });
  const blob = new Blob(['\uFEFF' + csv], { type: 'text/csv;charset=utf-8;' });
  const url = URL.createObjectURL(blob);
  const a = document.createElement('a');
  a.href = url;
  a.download = 'encuesta_HE_completa_' + new Date().toISOString().split('T')[0] + '.csv';
  a.click();
}

// Check for existing session — load directly (RLS allows anon read)
document.getElementById('loginScreen').style.display = 'none';
document.getElementById('dashboard').style.display = 'block';
loadData();
</script>
</body>
</html>
